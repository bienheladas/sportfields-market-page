<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive icon foreground — court icon scaled to fit the 66dp safe zone.
     Canvas: 108×108dp. Safe zone: center 66dp (from 21dp to 87dp on each axis).
     Icon uses 60dp centered → translate(24,24) scale(1.25) on the 48-unit SVG. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer rounded rectangle: 48-unit rect(7,7,34,34,rx=7) × 1.25 + translate(24,24) -->
    <!-- x=32.75 y=32.75 w=42.5 h=42.5 rx=8.75 -->
    <path
        android:pathData="M41.5,32.75 H66.5 A8.75,8.75 0 0,1 75.25,41.5 V66.5 A8.75,8.75 0 0,1 66.5,75.25 H41.5 A8.75,8.75 0 0,1 32.75,66.5 V41.5 A8.75,8.75 0 0,1 41.5,32.75 Z"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3.75"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"/>

    <!-- Center vertical line: (24,7)→(24,41) × 1.25 + translate(24,24) → (54,32.75)→(54,75.25) -->
    <path
        android:pathData="M54,32.75 V75.25"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3.75"
        android:strokeLineCap="round"/>

    <!-- Center circle: cx=24 cy=24 r=7 → cx=54 cy=54 r=8.75 -->
    <!-- Two semicircle arcs: top(54,45.25) → bottom(54,62.75) and back -->
    <path
        android:pathData="M54,45.25 A8.75,8.75 0 0,1 54,62.75 A8.75,8.75 0 0,0 54,45.25 Z"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3.75"/>

</vector>
